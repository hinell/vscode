      "await import(/* webpackChunkName: \"${1:chunkname}\" */ `$2${1:chunkname}`)",
      "$3"
    ],
    "description": "Immediate function invocation"
  },
  "throw": {
    "prefix": "throw",
    "body": [
      "throw new ${Error}(`${message}`)$0"
    ],
    "description": "Insert throw new Error(...)"
  },
  "if.throw": {
    "prefix": "if.throw",
    "body": [
      "if (${1:${TM_SELECTED_TEXT}})",
      "{",
      "\tthrow new ${2|this.constructor.IATE,TypeError,Error|}(`${ErrorName}`)",
      "}$0"
    ],
    "description": "if (...) { throw ... }"
  },
  "JSDoc Func return": {

{
  "directive check": {
    "prefix": "directive.check",
    "body": [
      "// @ts-${1| ,no|}check"
    ],
    "description": "@ts-check"
  },
  "directive refpath": {
    "prefix": "directive.refpath",
    "body": [
      "/// <reference path=\"$1\" />",
      "// Reference external file",
      "$0"
    ],
    "description": "<reference path ... >"
  },
  "declaration import custom": {
    "prefix": "import.custom",
    "description": "Import non-modules, like .css, .txt etc",
    "body": [
      "// The following should be put into d.ts",
      "// And imported or referenced as usual modula",
      "// Fixes imports of non-modules",
      "// See https://github.com/microsoft/TypeScript/issues/2709",
      "declare module '*.${1|txt,css,scss,svg,png,jpg|}';",
    ]
  },
  "class constructor": {
    "description": "class constructor({ ... })",
    "prefix": "class.c",
    "body": [
      "context: any;",
      "options: any;",
      "C: any;",
      "${1};",
      "${2};",
      "constructor(${1:foo}, ${2:bar}, options?: any, ${3:ctx}?:any) {",
      "\t//super($0)",
      "\tthis.C       = Object.assign({},  $3 || {});",
      "\tthis.options = Object.assign({}, options || {});",
      "\tthis.${4}    = ${4};",
      "\tthis.${5}    = ${5};",
      "} // CONSTRUCTOR END"
    ]
  },
  "class method normal parameters": {
    "description": "class method() with normal parameters",
    "prefix": "class:m",
    "body": [
      "",
      "//------------------------------------------------------------------------------",
      "${1:methodName}(${2:param0}, ${3:param1})",
      "{",
      "\tthis.${3:param1} = ${3:param1}$5",
      "\tthis.${2:param0} = ${2:param0}$4",
      "\t$0return this",
      "} // $1 end"
    ]
  },
  "class method destructive": {
    "description": "class method() with slow destructive {param, ...} parameters",
    "prefix": "class:m:d",
    "body": [
      "",
      "//------------------------------------------------------------------------------",
      "${1:methodName}({ ${2:param0}, ${3:param1} })",
      "{",
      "\tthis.${3:param1} = ${3:param1}$5",
      "\tthis.${2:param0} = ${2:param0}$4",
      "\t$0return this",
      "} // $1 end"
    ]
  },
  "class property deprecate": {
    "description": "Deprecate property",
    "prefix": "class:p:deprecate",
    "body": [
      "",
      "//------------------------------------------------------------------------------",
      "// TODO:REMOVE",
      "// ${2:property} property is DEPRECATED",
      "Object.defineProperty(${1:targetObject}, `${2:property}`, {",
      "    writable    : false,",
      "    enumerable  : false,",
      "    configurable: true,",
      "    get(){ throw new Error(`${2:property} field is deprecated`) },",
      "    set(){ this.revision }",
      "})"
    ]
  },
  "array reduce": {
    "prefix": "arr.reduce",
    "body": [
      "${1:array}.reduce(function (c, n, i, arr) {",
      "\treturn ${2:c}",
      "})$0"
    ],
    "description": "arr.reduce(function (){....}"
  },

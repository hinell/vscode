	"nodemon.config.new": {
		"scope": "json",
		"prefix": "nodemon.config.new",
		"isFileTemplate": true,
		"body": [
			"$0// https://github.com/remy/nodemon#config-files",
			"// https://github.com/remy/nodemon/blob/master/doc/sample-nodemon.md",
			"{",
			"\t\"restartable\": \"rs\",",
			"\t\"verbose\"    : ${1|true,false|},",
			"\t\"watch\"      : [\"${2|./dist,./src,/build|}\"],",
			"\t\"ignore\"     : [\"${3:.git}\"],",
			"\t\"execMap\"    : {",
			"\t\t\"${4:js}\"    : \"${5:node}\"",
			"\t},",
			"\t\"ext\"        : \"${7:js,jsx,json,ts,tsx}${8:,css,scss,less}\",",
			"\t\"stdout\"     : true",
			"}"
		],
		"description": "Produce nodemon config stub. Use it inside package.json or in separate nodemon.config"

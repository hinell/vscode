    "prefix": "arr.reduce =>",
    "body": [
      "${1:array}.reduce((c, n, i, arr) => {",
      "\treturn ${2:c}",
      "}$0"
    ],
    "description": "arr.reduce(() => {....}"
  },
  "array forEach": {
    "prefix": "arr.forEach",
